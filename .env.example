# AI 模型配置 (OpenAI 兼容)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key_here
MODEL_NAME=gpt-4-turbo

# 数据库配置 (Postgres)
PG_HOST=192.168.100.128
PG_PORT=5432
PG_USER=yilena
PG_PASSWORD=your_password_here
PG_DATABASE=luna

# Redis 配置
REDIS_HOST=192.168.100.128
REDIS_PORT=6379
REDIS_DB=1
REDIS_MAX_CONNECTIONS=300
REDIS_TIMEOUT=10

# 日志与可观测性配置
# 环境模式: dev=彩色控制台输出, prod=JSON输出
ENVIRONMENT=dev

# LangSmith 链路追踪（可选，不填则不启用）
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=werewolf
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 应用基础配置
DEBUG=True
