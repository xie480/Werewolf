# ==========================================
# 基础与安全配置
# ==========================================
# 运行环境 (dev, test, prod)
ENVIRONMENT=dev
# 是否开启调试模式 (true/false, 1/0)
DEBUG=true
# 加密密钥 (生产环境务必修改)
CRYPTO_KEY=your-secure-crypto-key-here

# ==========================================
# PostgreSQL 数据库配置
# ==========================================
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=your_db_user
PG_PASSWORD=your_db_password
PG_DATABASE=your_db_name

# ==========================================
# Redis 缓存配置
# ==========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
REDIS_MAX_CONNECTIONS=300
REDIS_TIMEOUT=10

# ==========================================
# 雪花算法配置 (分布式 ID 生成)
# ==========================================
# 数据中心 ID (0-31)
SNOWFLAKE_DATACENTER_ID=1
# 工作节点 ID (0-31)，多节点部署时需确保唯一
SNOWFLAKE_WORKER_ID=1

# ==========================================
# 记忆压缩模型配置
# ==========================================
COMPRESSION_MODEL_URL=https://api.openai.com/v1
COMPRESSION_MODEL_KEY=sk-your-openai-api-key
COMPRESSION_MODEL_NAME=gpt-3.5-turbo

# ==========================================
# 评测模型配置
# ==========================================
EVAL_MODEL_URL=https://api.openai.com/v1
EVAL_MODEL_KEY=sk-your-openai-api-key
EVAL_MODEL_NAME=gpt-4o-mini

# ==========================================
# LangSmith 链路追踪配置 (可选)
# ==========================================
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=werewolf
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ==========================================
# 动态 LLM 模型列表配置 (支持多个模型)
# ==========================================
# 格式说明：MODEL_{数字索引}_{字段名大写}=值
# 必填字段：MODEL_ID, PROVIDER

# 模型 1 配置示例 (OpenAI)
MODEL_1_MODEL_ID=default-openai
MODEL_1_PROVIDER=openai
MODEL_1_NAME=GPT-4 Turbo
MODEL_1_API_KEY=sk-your-openai-api-key
MODEL_1_BASE_URL=https://api.openai.com/v1
MODEL_1_MODEL_NAME=gpt-4-turbo
MODEL_1_TEMPERATURE=0.7
MODEL_1_MAX_TOKENS=1024
MODEL_1_TIMEOUT=15.0

# 模型 2 配置示例 (Anthropic / Claude)
# MODEL_2_MODEL_ID=claude-3-opus
# MODEL_2_PROVIDER=anthropic
# MODEL_2_NAME=Claude 3 Opus
# MODEL_2_API_KEY=sk-ant-your-anthropic-api-key
# MODEL_2_BASE_URL=https://api.anthropic.com
# MODEL_2_MODEL_NAME=claude-3-opus-20240229
# MODEL_2_TEMPERATURE=0.5
